    "method": "piecewise_monotonic_shrinkage",
    "description": "Fit a monotonic map from observed to target scores and shrink sparse scopes toward global profiles",
    "repeats": 3,
    "scope_prior": 12,
    "formula": "corrected_score = monotonic_map(raw_score) then reliability-weighted shrinkage(global, scoped)",
    "thresholds": {
